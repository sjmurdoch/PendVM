;; pendulum pal file
;; Frank Fig 8-2 multiplication routine (Reversibility for Efficient
;; Computing, pp. 213-214) with a small driver. Computes $5 = $3 * $4
;; via reversible grade-school shift-and-add, then returns to the
;; caller. Driver seeds m1=7, m2=11, so the forward run ends with
;; $5 = 77. The routine leaves every auxiliary register ($2, $28-$31)
;; and all scratch memory restored to zero, which lets check_reversible
;; round-trip the whole program.
;;
;; Register map (Frank table 8.1):
;;   $0  ZERO      $1  SP        $2  SRO/mask/temp
;;   $3  m1        $4  m2        $5  product accumulator
;;   $28 bit       $29 shifted   $30 position   $31 limit
start
        addi $1 200         ; SP in scratch region well past code
        addi $3 7           ; m1
        addi $4 11          ; m2
        bra mult            ; call — returns to the line after
        bra done            ; skip the routine, land on finish
subtop: bra subbot
mult:   swapbr $2           ; subroutine entry/exit (SRO trick)
        neg $2
        exch $2 $1          ; push return offset onto stack
        bra alloc4          ; save $28-$31 on stack
        addi $31 32         ; limit = 32
        addi $2 1           ; mask = 1
looptop: bne $30 $0 loopbot ; unless (position != 0) do
         andx $28 $3 $2     ;   bit <- m1 & mask
iftop:   beq $28 $0 ifbot   ;   if bit != 0 then
         sllvx $29 $4 $30   ;     shifted <- m2 << position
         add  $5 $29        ;     product += shifted
         sllvx $29 $4 $30   ;     shifted -> m2 << position  (clears $29)
ifbot:   beq $28 $0 iftop   ;   end if
         andx $28 $3 $2     ;   bit -> m1 & mask  (clears $28)
         rl $2 1            ;   mask <<= 1
         addi $30 1         ;   position++
loopbot: bne $30 $31 looptop ; while position != limit
         sub $30 $31        ; position -= limit  (clears $30)
         addi $2 -1         ; mask -= 1  (clears $2)
         addi $31 -32       ; limit -= 32  (clears $31)
         rbra alloc4        ; reverse-call alloc4 to restore $28-$31
         exch $2 $1         ; pop return offset
subbot: bra subtop
alloctop: bra allocbot
alloc4: swapbr $2
        neg $2
        addi $1 1
        exch $31 $1
        addi $1 1
        exch $30 $1
        addi $1 1
        exch $29 $1
        addi $1 1
        exch $28 $1
allocbot: bra alloctop
done:
finish
